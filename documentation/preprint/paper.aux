\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Synthetic validation of NPH exponent recovery. Estimated \(\mitalpha \) versus true \(\mitalpha \) under the working model, shown separately for the baseline synthetic branch (A) and a harder heteroskedastic branch (B). Both pairwise and collapse estimators recover \(\mitalpha \) with low bias when cross-cohort depletion geometry differs. The heteroskedastic branch shows reduced precision rather than structural failure. Error bars show replicate standard deviations.}}{25}{figure.6}\protected@file@percent }
\newlabel{fig:alpha_synth_recovery}{{6}{25}{Synthetic validation of NPH exponent recovery. Estimated \(\alpha \) versus true \(\alpha \) under the working model, shown separately for the baseline synthetic branch (A) and a harder heteroskedastic branch (B). Both pairwise and collapse estimators recover \(\alpha \) with low bias when cross-cohort depletion geometry differs. The heteroskedastic branch shows reduced precision rather than structural failure. Error bars show replicate standard deviations}{figure.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Objective functions for \(\mitalpha \) under the pooled Czech primary specification. The absolute scales of the two objectives differ by construction, so each curve is shifted so that its minimum is zero for visual comparability. Both estimators exhibit interior minima near \(\mitalpha \approx 1.18\)--1.19, but the curves remain shallow by the prespecified curvature criterion, indicating a preferred region rather than a strongly identified point estimate.}}{25}{figure.7}\protected@file@percent }
\newlabel{fig:alpha_czech_objective}{{7}{25}{Objective functions for \(\alpha \) under the pooled Czech primary specification. The absolute scales of the two objectives differ by construction, so each curve is shifted so that its minimum is zero for visual comparability. Both estimators exhibit interior minima near \(\alpha \approx 1.18\)--1.19, but the curves remain shallow by the prespecified curvature criterion, indicating a preferred region rather than a strongly identified point estimate}{figure.7}{}}
\@writefile{toc}{\contentsline {paragraph}{3.4.3 Diagnostics and identifiability of \(\mitalpha \)}{26}{paragraph*.64}\protected@file@percent }
